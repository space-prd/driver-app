# Supabase — copy to .env.local and fill in
# Settings → API in Supabase Dashboard
VITE_SUPABASE_URL=
# Newer projects expose a "Publishable key"; older ones use the "anon key".
# Either name works.
VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_ANON_KEY=

# Power Automate — "When a HTTP request is received" trigger URL.
# Fired once per trip-close. Leave blank to disable.
VITE_POWER_AUTOMATE_URL=
